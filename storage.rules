rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // לוגו בית ספר – רק המנהל של בית הספר יכול להעלות; כולם יכולים לקרוא (לטופס החיצוני)
    match /school_logos/{schoolId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == schoolId;
    }
    // לוגו שאלון חיצוני – רק המנהל יכול להעלות; כולם יכולים לקרוא (לטופס)
    match /external_survey_logos/{schoolId}/{surveyId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == schoolId;
    }
  }
}
